{
  "name": "eszerzodes-mcp",
  "version": "1.0.0",
  "description": "MCP server for Eszerződés.hu contract management platform",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WiredSign/eszerzodes-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/WiredSign/eszerzodes-mcp/issues"
  },
  "homepage": "https://github.com/WiredSign/eszerzodes-mcp#readme",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop eszerzodesmcp",
    "pm2:restart": "pm2 restart eszerzodesmcp",
    "pm2:logs": "pm2 logs eszerzodesmcp",
    "pm2:status": "pm2 status",
    "deploy": "npm run build && npm run pm2:start"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "adm-zip": "^0.5.16",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}